# Data source: "examples" or "data"
# Default is "examples" (safe for tests, new users)
RUMMAGE_DATA_SOURCE=examples

# Fio banka API tokens (64 characters each)
# Get tokens from: ib.fio.cz → Nastavení → API
# Each account needs its own token - use any descriptive suffix
# FIO_TOKEN_PERSONAL=your-64-character-token-here
# FIO_TOKEN_BUSINESS=another-token-here
# FIO_TOKEN_SAVINGS=yet-another-token

# Amundi Czech Republic (Moje Amundi portal)
# Used by: bun run src/importers/amundi/fetch.ts
# AMUNDI_USERNAME=your-email@example.com
# AMUNDI_PASSWORD=your-password
# AMUNDI_CLIENT_ID=prd-nma-215640  # default, rarely needs changing
# AMUNDI_CONTRACT=1234567890       # optional, auto-detected from API
